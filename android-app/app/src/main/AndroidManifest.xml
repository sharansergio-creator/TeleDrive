<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required by osmdroid to download and cache OpenStreetMap tiles -->
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <!-- Required to save evidence to gallery on Android 9 and below.
         Android 10+ uses MediaStore; no permission needed there. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeleDrive">
        <activity android:name=".LiveTripActivity"
            android:screenOrientation="portrait" />

        <!-- Invisible Camera Controller (Theme fixed to AppCompat Translucent) -->
        <activity
            android:name=".camera.CameraControllerActivity"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:theme="@style/Theme.TeleDrive.Translucent"
            android:configChanges="orientation|screenSize" />

        <activity
            android:name=".evidence.EventEvidenceActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name=".RideSummaryActivity"
            android:exported="false"
            android:noHistory="true"
            android:screenOrientation="portrait" />

        <!-- Legacy activity - kept for backward compatibility -->
        <activity android:name=".TripDetailsActivity"
            android:screenOrientation="portrait" />

        <!-- NEW: Restructured navigation activities -->
        <activity android:name=".TripsActivity"
            android:screenOrientation="portrait" />

        <activity android:name=".AnalyticsActivity"
            android:screenOrientation="portrait" />

        <activity android:name=".TripDetailActivity"
            android:screenOrientation="portrait" />

        <activity android:name=".EventMapActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity android:name=".profile.ProfileActivity"
            android:screenOrientation="portrait" />

        <activity android:name=".onboarding.OnboardingActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TeleDrive" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TeleDrive.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fixed repeated foregroundServiceType -->
        <service
            android:name=".services.SensorService"
            android:exported="false"
            android:foregroundServiceType="location|dataSync" />

    </application>
</manifest>