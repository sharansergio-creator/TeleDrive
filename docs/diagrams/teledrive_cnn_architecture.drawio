        <mxCell id="ann_config" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=9;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;spacingRight=8;fontFamily=Arial;" value="&lt;b style=&quot;font-size:9px&quot;&gt;Model Configuration&lt;/b&gt;&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;span style=&quot;font-size:8px&quot;&gt;Optimizer: Adam (LR = 0.001)&lt;br&gt;Loss: Sparse Categorical Crossentropy&lt;br&gt;Deployment: TensorFlow Lite&lt;br&gt;(On-device inference)&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="230" x="720" y="465" as="geometry" />
        </mxCell>
        <mxCell id="ann_perf" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=9;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;spacingRight=8;fontFamily=Arial;" value="&lt;b style=&quot;font-size:9px&quot;&gt;Performance Metrics&lt;/b&gt;&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;span style=&quot;font-size:8px&quot;&gt;Test Accuracy: &lt;b&gt;96%&lt;/b&gt;&lt;br&gt;Macro F1 Score: &lt;b&gt;92.9%&lt;/b&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="230" x="720" y="575" as="geometry" />
