<mxfile host="app.diagrams.net">
  <diagram id="cnn_architecture" name="1D-CNN Architecture">
    <mxGraphModel dx="1543" dy="1000" grid="1" gridSize="5" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontFamily=Arial;" value="1D-CNN Model Architecture for Time-Series Driving Event Classification" vertex="1">
          <mxGeometry height="30" width="540" x="130" y="15" as="geometry" />
        </mxCell>
        <mxCell id="input" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b style=&quot;font-size:12px&quot;&gt;INPUT LAYER&lt;/b&gt;&lt;br&gt;&lt;br&gt;Input Tensor (1 × 50 × 9)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;50 timesteps &amp;nbsp;×&amp;nbsp; 9 features:&lt;/span&gt;&lt;br&gt;&lt;i style=&quot;font-size:9px;color:#555&quot;&gt;(ax, ay, az, gx, gy, gz,&lt;br&gt;acc_mag, jerk_mag, speed)&lt;/i&gt;" vertex="1">
          <mxGeometry height="100" width="480" x="160" y="60" as="geometry" />
        </mxCell>
        <mxCell id="conv1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b&gt;CONVOLUTION BLOCK 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Conv1D (64 filters, kernel=3) → BatchNorm → ReLU → Dropout (0.3)&lt;/span&gt;" vertex="1">
          <mxGeometry height="55" width="440" x="180" y="195" as="geometry" />
        </mxCell>
        <mxCell id="conv2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b&gt;CONVOLUTION BLOCK 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Conv1D (128 filters, kernel=3) → BatchNorm → ReLU → Dropout (0.3)&lt;/span&gt;" vertex="1">
          <mxGeometry height="55" width="440" x="180" y="285" as="geometry" />
        </mxCell>
        <mxCell id="conv3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b&gt;CONVOLUTION BLOCK 3&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Conv1D (256 filters, kernel=3) → BatchNorm → ReLU → Dropout (0.3)&lt;/span&gt;" vertex="1">
          <mxGeometry height="55" width="440" x="180" y="375" as="geometry" />
        </mxCell>
        <mxCell id="pool" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6E6E6;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b style=&quot;font-size:11px&quot;&gt;Global Average Pooling&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:9px;color:#555&quot;&gt;Temporal Feature Aggregation&lt;/i&gt;" vertex="1">
          <mxGeometry height="50" width="360" x="220" y="465" as="geometry" />
        </mxCell>
        <mxCell id="dense1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b&gt;DENSE BLOCK 1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dense (128 neurons) → ReLU → Dropout (0.4)&lt;/span&gt;" vertex="1">
          <mxGeometry height="50" width="400" x="200" y="550" as="geometry" />
        </mxCell>
        <mxCell id="dense2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b&gt;DENSE BLOCK 2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Dense (64 neurons) → ReLU&lt;/span&gt;" vertex="1">
          <mxGeometry height="50" width="360" x="220" y="635" as="geometry" />
        </mxCell>
        <mxCell id="output_layer" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=4;" value="&lt;b style=&quot;font-size:11px&quot;&gt;OUTPUT LAYER&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;Dense (4 neurons) → Softmax&lt;/span&gt;" vertex="1">
          <mxGeometry height="50" width="360" x="220" y="720" as="geometry" />
        </mxCell>
        <mxCell id="classes" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=10;fontFamily=Arial;strokeWidth=2;verticalAlign=middle;spacing=4;" value="&lt;b style=&quot;font-size:11px&quot;&gt;Output Classes (Predicted Driving Event)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;NORMAL &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp; HARSH_ACCELERATION&lt;br&gt;HARSH_BRAKING &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp; UNSTABLE_RIDE&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="480" x="160" y="805" as="geometry" />
        </mxCell>
