<mxfile host="app.diagrams.net">
  <diagram id="preprocessing_pipeline" name="Signal Pre-processing Pipeline">
    <mxGraphModel dx="1323" dy="857" grid="1" gridSize="5" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="950" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontFamily=Arial;" value="Signal Pre-processing Pipeline for IMU Data (TeleDrive)" vertex="1">
          <mxGeometry height="30" width="550" x="125" y="15" as="geometry" />
        </mxCell>
        <mxCell id="input" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#6C8EBF;fontSize=11;fontFamily=Arial;verticalAlign=middle;spacing=6;" value="&lt;b style=&quot;font-size:12px&quot;&gt;Raw Sensor Window (50 samples)&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(85, 85, 85), rgb(164, 164, 164)); font-size: 9px; background-color: transparent;&quot;&gt;IMU Features:&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;font-size: 9px; color: rgb(85, 85, 85);&quot;&gt;(ax, ay, az, gx, gy, gz, speed)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="350" x="225" y="60" as="geometry" />
        </mxCell>
        <mxCell id="stage1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#444444;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=5;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Spike Rejection&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Acceleration Magnitude = √(ax² + ay² + az²)&lt;br&gt;Reject if magnitude &amp;gt; 15 m/s²&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="350" x="225" y="165" as="geometry" />
        </mxCell>
        <mxCell id="stage2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#444444;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=5;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Median Filter (3-point)&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;font-size:9px&quot;&gt;Applied to forward acceleration (ax)&lt;br&gt;Impulse noise removal&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="350" x="225" y="280" as="geometry" />
        </mxCell>
        <mxCell id="stage3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#444444;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=5;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Moving Average (5-point)&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;font size=&quot;1&quot; style=&quot;line-height: 160%;&quot;&gt;Sliding window average smoothing&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="350" x="225" y="395" as="geometry" />
        </mxCell>
        <mxCell id="stage4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#444444;fontSize=10;fontFamily=Arial;verticalAlign=middle;spacing=5;align=left;spacingLeft=15;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Feature Extraction&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px&quot;&gt;• Peak Forward Acceleration&lt;br&gt;• Minimum Forward Acceleration&lt;br&gt;• Mean Forward Acceleration&lt;br&gt;• Acceleration Standard Deviation&lt;br&gt;• Mean Gyroscope Magnitude&lt;br&gt;• Peak Gyroscope Magnitude&lt;br&gt;• Gyroscope Standard Deviation&lt;br&gt;• Vertical Acceleration Std Dev (Road Roughness)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color: rgb(102, 102, 102);&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Computed per 1-second window (50 samples)&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="200" width="350" x="225" y="510" as="geometry" />
        </mxCell>
        <mxCell id="output" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6A9F6A;fontSize=11;fontFamily=Arial;verticalAlign=middle;spacing=6;" value="&lt;b style=&quot;font-size:12px&quot;&gt;FeatureVector&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#555&quot;&gt;(8 statistical features)&lt;/span&gt;" vertex="1">
          <mxGeometry height="55" width="250" x="275" y="755" as="geometry" />
        </mxCell>
        <mxCell id="caption" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontFamily=Arial;fontColor=#333333;" value="&lt;i&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Figure 7.1: Signal pre-processing pipeline used in TeleDrive to transform raw IMU sensor data into feature vectors for driving event classification.&lt;/font&gt;&lt;/i&gt;" vertex="1">
          <mxGeometry height="25" width="630" x="100" y="830" as="geometry" />
        </mxCell>
        <mxCell id="side_note" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=9;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;spacingRight=8;fontFamily=Arial;" value="&lt;b style=&quot;font-size:9px&quot;&gt;&amp;nbsp; Purpose&lt;/b&gt;&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;&lt;span style=&quot;font-size:8px&quot;&gt;• Reduces sensor noise&lt;br&gt;• Preserves motion peaks&lt;br&gt;• Improves detection accuracy&lt;/span&gt;" vertex="1">
          <mxGeometry height="90" width="185" x="700" y="385" as="geometry" />
        </mxCell>
        <mxCell id="side_conn" edge="1" parent="1" source="stage3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=none;dashed=1;strokeColor=#999999;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="side_note">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a1" edge="1" parent="1" source="input" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1;" target="stage1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" edge="1" parent="1" source="stage1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1;" target="stage2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" edge="1" parent="1" source="stage2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1;" target="stage3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" edge="1" parent="1" source="stage3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1;" target="stage4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5" edge="1" parent="1" source="stage4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1;" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
